# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Database (local Homebrew Postgres — create once if not using Docker)
# psql -d postgres -c "CREATE USER rideuser WITH PASSWORD 'ridepass';"
# psql -d postgres -c "CREATE DATABASE ridebooking OWNER rideuser;"
# cd Backend && alembic upgrade head
DATABASE_URL=postgresql+asyncpg://rideuser:ridepass@localhost:5432/ridebooking

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:8000

# Twilio Verify — required for real SMS OTP in production
# Create a Verify Service at https://console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# When Twilio is NOT configured and DEBUG=true, the API returns the OTP in the
# send-otp response body for local development only. Never enable DEBUG in production
# without Twilio configured.
