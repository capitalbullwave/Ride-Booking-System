{
  "info": {
    "name": "RideBooking API",
    "description": "Complete API collection for Ride Booking Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/../health"
          }
        }
      ]
    },
    {
      "name": "User Auth",
      "item": [
        {
          "name": "Register User",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "pm.collectionVariables.set('access_token', json.access_token);",
                "pm.collectionVariables.set('refresh_token', json.refresh_token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Password@123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
            },
            "url": "{{base_url}}/auth/user/register"
          }
        },
        {
          "name": "Login User",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "pm.collectionVariables.set('access_token', json.access_token);",
                "pm.collectionVariables.set('refresh_token', json.refresh_token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{base_url}}/auth/user/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/user/me"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/auth/user/verify-otp"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": "{{base_url}}/auth/user/forgot-password"
          }
        }
      ]
    },
    {
      "name": "Driver Auth",
      "item": [
        {
          "name": "Register Driver",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"driver@example.com\",\n  \"phone\": \"9876543211\",\n  \"password\": \"Password@123\",\n  \"first_name\": \"Mike\",\n  \"last_name\": \"Driver\",\n  \"license_number\": \"DL1234567890\"\n}"
            },
            "url": "{{base_url}}/auth/driver/register"
          }
        },
        {
          "name": "Login Driver",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"driver@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{base_url}}/auth/driver/login"
          }
        }
      ]
    },
    {
      "name": "Rides",
      "item": [
        {
          "name": "Estimate Fare",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_lat\": 19.0760,\n  \"pickup_lng\": 72.8777,\n  \"dropoff_lat\": 19.0896,\n  \"dropoff_lng\": 72.8656\n}"
            },
            "url": "{{base_url}}/rides/estimate"
          }
        },
        {
          "name": "Book Ride",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_address\": \"Mumbai Central\",\n  \"pickup_lat\": 19.0760,\n  \"pickup_lng\": 72.8777,\n  \"dropoff_address\": \"Bandra West\",\n  \"dropoff_lat\": 19.0596,\n  \"dropoff_lng\": 72.8295,\n  \"vehicle_type_id\": \"VEHICLE_TYPE_UUID\",\n  \"payment_method\": \"CASH\"\n}"
            },
            "url": "{{base_url}}/rides"
          }
        },
        {
          "name": "Get Active Ride",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/rides/active"
          }
        },
        {
          "name": "Ride History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/rides/history?page=1&page_size=20"
          }
        },
        {
          "name": "Cancel Ride",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Changed plans\"\n}"
            },
            "url": "{{base_url}}/rides/{{ride_id}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/wallet"
          }
        },
        {
          "name": "Top Up Wallet",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"payment_method\": \"RAZORPAY\"\n}"
            },
            "url": "{{base_url}}/wallet/topup"
          }
        },
        {
          "name": "Wallet Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/wallet/transactions"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "pm.collectionVariables.set('access_token', json.access_token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ridebook.com\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": "{{base_url}}/admin/auth/login"
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "List Drivers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/drivers"
          }
        },
        {
          "name": "List Rides",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/rides"
          }
        }
      ]
    }
  ]
}
