# Local development — use your Backend on :8000 (reads OPENAI_API_KEY from Backend/.env)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Staging / production example:
# NEXT_PUBLIC_API_URL=https://ride-application-backend.onrender.com
# BACKEND_URL=https://ride-application-backend.onrender.com
# NEXT_PUBLIC_SITE_URL=https://your-staging-site.example.com

# Optional App Store links for Download App menu
NEXT_PUBLIC_IOS_APP_STORE_URL=
NEXT_PUBLIC_CAPTAIN_IOS_APP_STORE_URL=
